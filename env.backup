# ------------------------------
# Lidarr database mode
# Default SAFE: SQLite (false)
# Flip true ONLY if your Lidarr build supports Postgres and you have created the DB.
# ------------------------------
LIDARR_USE_POSTGRES=true
LIDARR_DB=lidarr_db
LIDARR_DB_USER=lidarr
LIDARR_DB_PASSWORD=lidarr123

# ------------------------------
# App Specific Keys
# ------------------------------
