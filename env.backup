JWT_SECRET=Trustno12345
NOTIFIARR_API_KEY=your_notifiarr_api_key_here

# ------------------------------
# NPM (Nginx Proxy Manager) MariaDB
# ------------------------------
NPM_MYSQL_ROOT_PASSWORD=npm
NPM_MYSQL_USER=npm
NPM_MYSQL_PASSWORD=npm
NPM_MYSQL_DATABASE=npm

# ------------------------------
# Optional tuning
# ------------------------------
